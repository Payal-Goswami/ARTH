# ─── Application ───────────────────────────────────────────────────────────────
APP_NAME=ARTH
APP_ENV=development
DEBUG=true
SECRET_KEY=YOUR_SECRET_KEY_HERE_CHANGE_IN_PRODUCTION
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Database ──────────────────────────────────────────────────────────────────
# Option 1: Direct PostgreSQL
DATABASE_URL=postgresql+asyncpg://USER:URL_ENCODED_PASSWORD@HOST:PORT/arth_db

# Option 2: Supabase (recommended)
# DATABASE_URL=postgresql+asyncpg://postgres:URL_ENCODED_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_KEY

# ─── Google Gemini ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-1.5-flash

# ─── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ─── Security ──────────────────────────────────────────────────────────────────
ALGORITHM=HS256
BCRYPT_ROUNDS=12
